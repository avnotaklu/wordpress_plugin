<?xml version="1.0"?>
<ruleset name="Cal ID Embed">
	<description>WordPress coding standards for Cal ID Embed.</description>

	<file>.</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>

	<rule ref="WordPress" />
	<rule ref="WordPress-Core" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-Extra" />
	<rule ref="PHPCompatibilityWP">
		<properties>
			<property name="testVersion" value="7.4-"/>
		</properties>
	</rule>

	<config name="installed_paths" value="vendor/wp-coding-standards/wpcs, vendor/phpcompatibility/phpcompatibility-wp" />
</ruleset>
